{
  "name": "@humation/web-component",
  "version": "1.0.1",
  "type": "module",
  "description": "<humation-avatar> custom element for Humation avatars.",
  "license": "MIT",
  "keywords": [
    "avatar",
    "svg",
    "web-components",
    "custom-elements",
    "humation",
    "illustration",
    "user-icon",
    "profile-picture",
    "deterministic-avatar",
    "avatar-generator"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "dependencies": {
    "@humation/core": "1.0.1"
  },
  "devDependencies": {
    "@humation/assets-humation-1": "1.0.1",
    "typescript": "^5.0.0"
  }
}
